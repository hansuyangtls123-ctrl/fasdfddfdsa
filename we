    SkinBtn.Text = "Skin Unlock 진행 중..."
    SkinBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)

    task.spawn(function()
        local success = 0
        local total = 0

        for name, cosmetic in pairs(CosmeticLibrary.Cosmetics) do
            if cosmetic.Type == "Skin" and not name:lower():find("finisher") then
                total += 1
                Status.Text = string.format("Skin Unlock 중...\n%d/%d\n%s", success, total, name)
                
