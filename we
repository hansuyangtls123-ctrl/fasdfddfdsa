-- ==================== 드래그 기능 ====================
local dragging, dragInput, dragStart, startPos
MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
    end
end)

MainFrame.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

MainFrame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

-- ==================== Remote 찾기 ====================
local equipRemote = nil
local function findRemotes()
    local remotesFolder = ReplicatedStorage:FindFirstChild("Remotes")
    if remotesFolder then
        local data = remotesFolder:FindFirstChild("Data")
        if data then
            equipRemote = data:FindFirstChild("EquipCosmetic") or data:FindFirstChild("Equip") 
        end
    end
end
findRemotes()

-- ==================== Unlock 함수 ====================
local function unlockWeapon(weaponName)
    if not equipRemote then return false end
    for attempt = 1, 4 do
        pcall(function()
            equipRemote:FireServer(weaponName, "Ownership", weaponName, {})
            task.wait(0.07)
            equipRemote:FireServer(weaponName, "Skin", "Default", {})
            task.wait(0.07)
            equipRemote:FireServer("AllWeapons", weaponName, "Unlock", {})
        end)
        task.wait(0.16)
    end
    return true
end

local function unlockSkin(name)
    if not equipRemote then return false end
    for attempt = 1, 3 do
        local success = pcall(function()
            equipRemote:FireServer("AllWeapons", "Skin", name, {IsInverted = false})
        end)
        if success then return true end
        task.wait(0.13)
    end
    return false
end

-- ==================== 실행 ====================
local function updateProgress(bar, value)
    TweenService:Create(bar, TweenInfo.new(0.4, Enum.EasingStyle.Quad), {Size = UDim2.new(value, 0, 1, 0)}):Play()
end

WeaponsBtn.MouseButton1Click:Connect(function()
    if WeaponsBtn.Text:find("중") then return end
    WeaponsBtn.Text = "무기 Unlock 진행 중..."
    WeaponsBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)

    task.spawn(function()
        local count = 0
        local total = 0

        for name, _ in pairs(CosmeticLibrary.Cosmetics) do
            if name:find("Knife") or name:find("Gun") or name:find("Weapon") or name:find("Sword") then
                total += 1
                Status.Text = string.format("무기 Unlock 중...\n%d/%d\n%s", count, total, name)
                unlockWeapon(name)
                count += 1
                updateProgress(ProgressBar, count / total)
                task.wait(0.18)
            end
        end

        Status.Text = string.format("무기 Unlock 완료!\n총 %d개 시도", count)
        WeaponsBtn.Text = "무기 Unlock 완료 ✓"
    end)
end)

SkinBtn.MouseButton1Click:Connect(function()
