-- 클라이언트 표시 강화
local originalGet = DataController.Get
DataController.Get = function(self, key)
    local data = originalGet(self, key)
    if key == "WeaponInventory" or key == "CosmeticInventory" then
        local proxy = data and table.clone(data) or {}
        for name, v in pairs(CosmeticLibrary.Cosmetics) do
            if v.Type == "Skin" or name:find("Weapon") or name:find("Knife") then
                proxy[name] = proxy[name] or {Owned = true, Unlocked = true}
            end
        end
        return proxy
    end
    return data
end

